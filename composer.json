{
    "name": "purecart/purecart",
    "description": "The complete digital product suite for WooCommerce. Sell plugins, SaaS, and any digital file with secure delivery, licensing, and subscriptions.",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "php-stubs/wordpress-stubs": "^6.9",
        "php-stubs/woocommerce-stubs": "^8.0",
        "overtrue/phplint": "^9.0",
        "phpunit/phpunit": "^10.0",
        "brain/monkey": "^2.6",
        "phpstan/phpstan": "^1.10",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "carthage-software/mago": "^1.24.0"
    },
    "autoload": {
        "psr-4": {
            "PureCart\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PureCart\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint":    "vendor/bin/phplint --no-cache .",
        "analyze": "vendor/bin/phpstan analyse --memory-limit=1G",
        "test":    "vendor/bin/phpunit --testdox",
        "format":  "vendor/bin/mago format"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "automattic/jetpack-autoloader": true
        },
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "extra": {
        "wordpress-install-dir": "wp"
    }
}
